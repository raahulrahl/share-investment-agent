{
  "author": "paras@getbindu.com",
  "name": "share-investment-agent",
  "description": "A Bindu AI agent for comprehensive share investment analysis",
  "version": "1.0.0",
  "recreate_keys": false,
  "skills": [
    "skills/share-investment"
  ],
  "capabilities": {},
  "agent_trust": "low",
  "debug_mode": true,
  "debug_level": 2,
  "deployment": {
    "url": "http://0.0.0.0:3773",
    "expose": true,
    "protocol_version": "1.0.0",
    "proxy_urls": [
      "0.0.0.0"
    ],
    "cors_origins": [
      "*"
    ]
  },
  "num_history_sessions": 5,
  "environment_variables": [
    {
      "key": "OPENROUTER_API_KEY",
      "description": "OpenRouter API key for LLM model access",
      "required": true
    }
  ]
}
